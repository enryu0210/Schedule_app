{
  "name": "schedule-app-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "일정공방 안드로이드 앱 (Capacitor 셸 — 화면은 web/ 빌드 결과를 그대로 담는다)",
  "scripts": {
    "build:web": "npm --prefix ../web run build",
    "sync": "npm run build:web && cap sync android",
    "open": "cap open android",
    "apk": "cd android && gradlew.bat assembleDebug",
    "install:phone": "cd android && gradlew.bat installDebug"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.7",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.7",
    "@capacitor/app": "^7.1.2",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/core": "^7.6.7"
  }
}
