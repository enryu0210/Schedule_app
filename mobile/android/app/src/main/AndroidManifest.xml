<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              카카오 로그인 복귀용 딥링크.

              흐름: 앱 → (크롬 커스텀탭)카카오 로그인 → Supabase 콜백 →
                    ilgongbang://auth-callback#access_token=... → 이 인텐트필터가 앱을 다시 깨운다.
              웹뷰 안에서 카카오 로그인을 시키지 않는 이유: 인앱 웹뷰 로그인은 카카오가 막을 수 있고,
              폰에 이미 로그인된 카카오 세션(카카오톡/크롬)을 재사용하지 못해 매번 아이디를 치게 된다.

              주의: 이 주소는 Supabase 대시보드의 Redirect URLs 에도 등록돼야 한다.
                    (Authentication → URL Configuration)
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="ilgongbang" android:host="auth-callback" />
            </intent-filter>
        </activity>

        <!--
          상시 알림을 다시 그려야 할 때 깨어나는 리시버.
          exported=false — 우리 알람과 시스템 부팅 방송만 받으면 되고, 남이 부를 이유가 없다.
        -->
        <receiver
            android:name=".ScheduleReceiver"
            android:exported="false">
            <intent-filter>
                <!-- 재부팅하면 알림도 알람도 사라진다 → 부팅 직후 스스로 되살린다 -->
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!--
          홈 화면 위젯 ("지금 하는 일정").

          exported=true 여야 한다 — 위젯은 **런처(다른 앱)가** 우리 리시버를 부르는 구조라
          false 로 두면 위젯 목록에 뜨긴 해도 갱신 방송을 못 받는다.
          받는 것은 시스템의 위젯 방송뿐이라 노출해도 위험하지 않다.
        -->
        <receiver
            android:name=".ScheduleWidget"
            android:label="@string/widget_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_schedule_info" />
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- 상시 알림 ("지금 하는 일정") -->
    <!-- 안드로이드 13+ 는 알림을 띄우려면 사용자 허락이 필요하다 (앱에서 물어본다) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 재부팅 후 알림을 되살리기 위해 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- 일정이 시작/종료되는 '그 순간'에 알림·위젯을 갈아끼우기 위해.
         사용자가 이 권한을 거두면 코드가 부정확한 알람으로 물러선다(조금 늦게 갱신) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!--
      SCHEDULE_EXACT_ALARM 은 안드로이드 14+ 에서 **기본 거부**라, 실제로는 부정확 알람으로 물러서고
      있었다(실측: 15분마다 울려야 할 알람이 18~23분씩 밀렸다). 그러면 일정이 바뀌어도 알림·위젯의
      '제목'이 한참 뒤에야 바뀐다.
      USE_EXACT_ALARM 은 시계/캘린더처럼 **시각이 기능의 본질인 앱**에 주어지는 권한으로,
      사용자에게 묻지 않고 자동 승인된다. 이 앱은 "지금 몇 시에 무엇을 하는가"가 존재 이유다.
      (※ Play 스토어에 올릴 때는 이 권한의 정당성을 심사받아야 한다 — 지금은 APK 직접 배포)
    -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
</manifest>
