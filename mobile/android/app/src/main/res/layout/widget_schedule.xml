<?xml version="1.0" encoding="utf-8"?>
<!--
  홈 위젯 화면 — "지금 하는 일정".

  위젯 레이아웃은 RemoteViews 로 그려지므로 **쓸 수 있는 뷰가 제한**된다
  (ConstraintLayout·커스텀 뷰 불가). LinearLayout + TextView + ProgressBar 로만 짠다.

  화면 구성은 알림(ScheduleNotifier)과 일부러 똑같이 맞췄다 —
  같은 정보가 알림과 위젯에서 다르게 보이면 사용자는 둘 중 뭘 믿어야 할지 모른다.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <!-- 무엇을 기준으로 띄우는 중인지(개인 프리셋 이름 / 조직 이름).
         위젯이 옛 시간표를 붙들고 있는지 한눈에 알 수 있어야 한다. -->
    <TextView
        android:id="@+id/widget_source"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#B6A794"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="일정공방" />

    <!-- 지금 하는 일정 (가장 크게 — 위젯을 보는 이유 그 자체) -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#2A231D"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="지금은 비어 있어요" />

    <!-- "17:00 까지 · 2시간 10분 남음" -->
    <TextView
        android:id="@+id/widget_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textSize="12sp"
        android:textColor="#8A7C6D"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="" />

    <ProgressBar
        android:id="@+id/widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="8dp"
        android:progressDrawable="@drawable/widget_progress"
        android:max="100"
        android:progress="0" />

    <!-- 다음 일정 (작게) -->
    <TextView
        android:id="@+id/widget_next"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="12sp"
        android:textColor="#8A7C6D"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="" />
</LinearLayout>
