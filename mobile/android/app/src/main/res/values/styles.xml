<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>

        <!--
          안드로이드 15(API 35)부터 targetSdk 35 인 앱에는 edge-to-edge 가 "강제" 적용된다.
          그러면 웹뷰가 상태바(시계·배터리) 밑까지 파고들어, 우리 상단바(햄버거·로그아웃)가
          상태바에 가려 읽히지도 눌리지도 않는다. (Z Flip3 / Android 15 에서 실제로 겪음)

          웹뷰 앱의 정석은 CSS 의 env(safe-area-inset-top) 으로 여백을 주는 것이지만,
          안드로이드 웹뷰의 safe-area 값은 '노치(컷아웃)'만 반영하고 상태바 높이는 반영하지 않아
          기기마다 값이 들쭉날쭉하다. 그래서 창 자체를 예전(비 edge-to-edge) 동작으로 되돌린다.

          주의: 이 플래그는 과도기용이다. targetSdk 를 36 으로 올리면 더 이상 먹지 않으므로,
                그때는 네이티브에서 WindowInsets 를 읽어 웹뷰에 여백을 주는 방식으로 바꿔야 한다.
        -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:targetApi="35">true</item>
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <!-- 창은 이 스플래시 테마로 만들어지므로, 같은 플래그가 여기에도 있어야 한다. -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:targetApi="35">true</item>
    </style>
</resources>
