<?xml version="1.0" encoding="utf-8"?>
<!--
  위젯 카드 배경. 앱의 카드 색(tokens.css 의 card / border 토큰)을 그대로 가져왔다.
  XML 주석 안에는 붙임표 두 개를 연달아 쓸 수 없어서 토큰 이름을 그대로 옮기지 못한다.
  홈 화면 배경이 무엇이든 글자가 읽히도록 불투명하게 채운다.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FFFDF9" />
    <stroke android:width="1dp" android:color="#ECE2D5" />
    <corners android:radius="16dp" />
</shape>
