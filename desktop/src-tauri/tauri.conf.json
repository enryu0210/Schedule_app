{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Schedule Widget",
  "version": "0.1.0",
  "identifier": "com.enryu.schedule.widget",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "label": "widget",
        "title": "일정공방 위젯",
        "url": "https://schedule-repo-eight.vercel.app/?widget=1",
        "width": 300,
        "height": 230,
        "minWidth": 220,
        "minHeight": 150,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"]
  }
}
